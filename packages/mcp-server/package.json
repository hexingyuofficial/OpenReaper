{
  "name": "@streetlight/mcp-server",
  "version": "0.0.0",
  "private": true,
  "description": "Streetlight MCP server. Step 1: ping round trip via file queue.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "streetlight-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "src"
