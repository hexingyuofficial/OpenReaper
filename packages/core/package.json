{
  "name": "@streetlight/core",
  "version": "0.0.0",
  "private": true,
  "description": "Streetlight kernel: registry, risk, refs, result, queue types.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit || tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
